# Copy this file to .env and fill in your values
# cp .env.example .env

# Anthropic API key — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Set to "true" to enable Claude API fallback for ambiguous HTML blocks
# Set to "false" to use deterministic parser only
USE_CLAUDE_FALLBACK=true

# Claude model to use for fallback
CLAUDE_MODEL=claude-sonnet-4-5

# Allowed origins for CORS (comma-separated, no spaces)
# For development: http://localhost:5173
CORS_ORIGINS=http://localhost:5173
